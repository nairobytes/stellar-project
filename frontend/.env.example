# InvoiceFi Frontend - Environment Configuration

# Contract Configuration (copy your deployed IDs into .env — see root README)
VITE_CONTRACT_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
VITE_USDC_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Network Configuration
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Mobile wallet pairing (Freighter, xBull, etc. in Chrome on phone)
# 1. Create a free project at https://cloud.reown.com
# 2. Project settings → Allowed origins → add your dev URL, e.g. http://192.168.1.67:3000
# 3. Copy the Project ID below, restart: npm run dev -- --host 0.0.0.0
# 4. On phone: Choose wallet → WalletConnect → Freighter → approve on Testnet
# Leave empty to skip WalletConnect (use Freighter in-app browser instead).
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# API Configuration (optional, for backend)
VITE_API_URL=http://localhost:3001
